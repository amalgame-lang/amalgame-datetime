// Test sample for amalgame-datetime — Instant / Duration /
// Stopwatch + ISO 8601 round-trip.
//
// Avoid the bare keyword "ns"+"pace" in comments.

namespace UserApp

import Amalgame.DateTime

public class Program {
    public static void Main() {

        // ── Instant.Now produces a non-trivial value ──
        let now: Instant = Instant.Now()
        let nowS: int = now.UnixSeconds()
        // Anything after Jan 1 2020 (= 1577836800s) is plausible.
        if (nowS > 1577836800) {
            Console.WriteLine("[PASS] Now plausible")
        } else {
            Console.WriteLine("[FAIL] Now plausible")
        }

        // ── FromUnixSeconds + accessors ───────────────
        let i1: Instant = Instant.FromUnixSeconds(1700000000)
        let s1: int = i1.UnixSeconds()
        let m1: int = i1.UnixMillis()
        let n1: int = i1.UnixNanos()
        let okFrom: bool = (s1 == 1700000000) && (m1 == 1700000000000) && (n1 == 1700000000000000000)
        if (okFrom) {
            Console.WriteLine("[PASS] FromUnixSeconds")
        } else {
            Console.WriteLine("[FAIL] FromUnixSeconds")
        }

        // ── ISO 8601 round-trip ───────────────────────
        let iso1: string = "2026-05-09T22:30:00.000000000Z"
        let r1: InstantResult = Instant.Parse(iso1)
        if (r1.IsOk()) {
            let v: Instant = r1.GetValue()
            let formatted: string = v.Format()
            if (formatted == iso1) {
                Console.WriteLine("[PASS] iso round trip")
            } else {
                Console.WriteLine("[FAIL] iso round trip got: " + formatted)
            }
        } else {
            Console.WriteLine("[FAIL] iso round trip parse failed")
        }

        // ── Parse with fractional seconds (truncates >9) ──
        let iso2: string = "2026-01-15T08:00:00.123456Z"
        let r2: InstantResult = Instant.Parse(iso2)
        if (r2.IsOk()) {
            let v2: Instant = r2.GetValue()
            let n2: int = v2.UnixNanos()
            // 2026-01-15T08:00:00Z = 1768464000 unix seconds.
            // + 0.123456 fractional → 123_456_000 ns.
            let want: int = 1768464000000000000 + 123456000
            if (n2 == want) {
                Console.WriteLine("[PASS] iso fractional")
            } else {
                Console.WriteLine("[FAIL] iso fractional got: " + String_FromInt(n2))
            }
        } else {
            Console.WriteLine("[FAIL] iso fractional parse failed")
        }

        // ── Parse rejects non-UTC offsets ─────────────
        let bad1: InstantResult = Instant.Parse("2026-05-09T22:30:00+02:00")
        let bad2: InstantResult = Instant.Parse("not a date")
        let bad3: InstantResult = Instant.Parse("2026-05-09")
        if (!bad1.IsOk() && !bad2.IsOk() && !bad3.IsOk()) {
            Console.WriteLine("[PASS] parse rejects bad")
        } else {
            Console.WriteLine("[FAIL] parse rejects bad")
        }

        // ── Instant arithmetic (Add / Subtract / Since) ──
        let base: Instant = Instant.FromUnixSeconds(1700000000)
        let plusHour: Duration = Duration.FromHours(1)
        let later: Instant = base.Add(plusHour)
        let laterS: int = later.UnixSeconds()
        if (laterS == 1700003600) {
            Console.WriteLine("[PASS] Instant.Add hours")
        } else {
            Console.WriteLine("[FAIL] Instant.Add hours")
        }
        let earlier: Instant = base.Subtract(plusHour)
        let earlierS: int = earlier.UnixSeconds()
        if (earlierS == 1699996400) {
            Console.WriteLine("[PASS] Instant.Subtract hours")
        } else {
            Console.WriteLine("[FAIL] Instant.Subtract hours")
        }
        let diff: Duration = later.Since(base)
        let diffSec: int = diff.Seconds()
        if (diffSec == 3600) {
            Console.WriteLine("[PASS] Instant.Since")
        } else {
            Console.WriteLine("[FAIL] Instant.Since")
        }

        // ── Comparison ─────────────────────────────────
        if (base.IsBefore(later) && later.IsAfter(base) && base.Equals(base)) {
            Console.WriteLine("[PASS] Instant comparison")
        } else {
            Console.WriteLine("[FAIL] Instant comparison")
        }

        // ── Duration constructors ──────────────────────
        let dms: Duration = Duration.FromMillis(2500)
        let dsec: Duration = Duration.FromSeconds(2)
        let dminus: Duration = dms.Minus(dsec)
        let dminusMs: int = dminus.Millis()
        if (dminusMs == 500) {
            Console.WriteLine("[PASS] Duration arithmetic")
        } else {
            Console.WriteLine("[FAIL] Duration arithmetic")
        }
        let dx2: Duration = dsec.Times(3)
        let dx2Sec: int = dx2.Seconds()
        if (dx2Sec == 6) {
            Console.WriteLine("[PASS] Duration Times")
        } else {
            Console.WriteLine("[FAIL] Duration Times")
        }
        let dneg: Duration = dsec.Negate()
        let dnegSec: int = dneg.Seconds()
        if (dnegSec == -2 && dneg.IsNegative()) {
            Console.WriteLine("[PASS] Duration Negate")
        } else {
            Console.WriteLine("[FAIL] Duration Negate")
        }

        // ── Duration.Format ───────────────────────────
        let zeroD: Duration = new Duration(0)
        let nsD: Duration = new Duration(500)
        let usD: Duration = new Duration(1500)
        let msD: Duration = new Duration(1500000)
        let secD: Duration = Duration.FromSeconds(5)
        let minD: Duration = Duration.FromSeconds(125)
        let hrD: Duration  = Duration.FromSeconds(3725)
        let z: string  = zeroD.Format()
        let ns: string = nsD.Format()
        let us: string = usD.Format()
        let ms: string = msD.Format()
        let sc: string = secD.Format()
        let mn: string = minD.Format()
        let hr: string = hrD.Format()
        if (z == "0s")     { Console.WriteLine("[PASS] dur fmt zero") }     else { Console.WriteLine("[FAIL] dur fmt zero got: " + z) }
        if (ns == "500ns") { Console.WriteLine("[PASS] dur fmt ns") }       else { Console.WriteLine("[FAIL] dur fmt ns got: " + ns) }
        if (us == "1us")   { Console.WriteLine("[PASS] dur fmt us") }       else { Console.WriteLine("[FAIL] dur fmt us got: " + us) }
        if (ms == "1ms")   { Console.WriteLine("[PASS] dur fmt ms") }       else { Console.WriteLine("[FAIL] dur fmt ms got: " + ms) }
        if (sc == "5s")    { Console.WriteLine("[PASS] dur fmt s") }        else { Console.WriteLine("[FAIL] dur fmt s got: " + sc) }
        if (mn == "2m5s")  { Console.WriteLine("[PASS] dur fmt min") }      else { Console.WriteLine("[FAIL] dur fmt min got: " + mn) }
        if (hr == "1h2m5s"){ Console.WriteLine("[PASS] dur fmt hour") }     else { Console.WriteLine("[FAIL] dur fmt hour got: " + hr) }

        // ── Stopwatch produces non-negative elapsed ──
        let sw: Stopwatch = new Stopwatch()
        var sum: int = 0
        for i in 0..10000 { sum = sum + i }
        let elap: Duration = sw.Elapsed()
        let elapNs: int = elap.Nanos()
        if (elapNs >= 0) {
            Console.WriteLine("[PASS] Stopwatch elapsed")
        } else {
            Console.WriteLine("[FAIL] Stopwatch elapsed")
        }
        // Reset + a second sample
        let pre: Duration = sw.Reset()
        let preNs: int = pre.Nanos()
        let elap2: Duration = sw.Elapsed()
        let elap2Ns: int = elap2.Nanos()
        if (preNs >= 0 && elap2Ns >= 0 && elap2Ns < preNs + 1000000000) {
            Console.WriteLine("[PASS] Stopwatch reset")
        } else {
            Console.WriteLine("[FAIL] Stopwatch reset")
        }
    }
}
